# ── Database ──────────────────────────────────
DATABASE_URL=postgresql://churn_user:churn_pass@localhost:5432/churn_db

# ── Kafka ─────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_CUSTOMER_EVENTS=customer-events
KAFKA_TOPIC_CHURN_PREDICTIONS=churn-predictions
KAFKA_CONSUMER_GROUP=churn-feature-group

# ── MLflow ────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=churn-prediction
MODEL_NAME=churn_predictor
MODEL_STAGE=Production

# ── AWS ───────────────────────────────────────
AWS_REGION=eu-west-2
AWS_ACCOUNT_ID=123456789012
ECR_REPOSITORY=churn-prediction-api
ECS_CLUSTER=churn-cluster
ECS_SERVICE=churn-api-service

# ── API ───────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# ── Monitoring ────────────────────────────────
PROMETHEUS_PORT=8001
DRIFT_THRESHOLD=0.15
ALERT_EMAIL=yourteam@company.com
